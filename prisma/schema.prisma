generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String
  role          String    @default("user") // "user" | "admin"
  enabled       Boolean   @default(true)
  inviteToken   String?   @unique
  inviteExpires DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  posts              Post[]
  voiceCorpusEntries VoiceCorpusEntry[]
  linkedInToken      LinkedInToken?
  followerSnapshots  FollowerSnapshot[]
  scheduledPosts     ScheduledPost[]
  userSettings       UserSetting[]
  researchBriefs     ResearchBrief[]
}

model UserSetting {
  userId    String
  key       String
  value     String
  iv        String?
  tag       String?
  encrypted Boolean  @default(false)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, key])
}

model Post {
  id              String    @id @default(cuid())
  title           String
  body            String    @default("")
  status          String    @default("IDEA")
  linkedinPostId  String?
  publishedAt     DateTime?
  topicTags       String    @default("")
  researchBriefId String?
  voiceScore      Float?
  userId          String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  researchBrief ResearchBrief? @relation(fields: [researchBriefId], references: [id])
  analytics     PostAnalytics[]
  versions      PostVersion[]

  @@index([userId])
}

model ResearchBrief {
  id        String   @id @default(cuid())
  topic     String
  summary   String
  keyClaims String
  sources   String
  userId    String
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts Post[]

  @@index([userId])
}

model PostVersion {
  id        String   @id @default(cuid())
  postId    String
  body      String
  note      String?
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model PostAnalytics {
  id            String   @id @default(cuid())
  postId        String
  snapshotAt    DateTime @default(now())
  followerCount Int
  impressions   Int?
  reactions     Int?
  comments      Int?
  shares        Int?
  post          Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model FollowerSnapshot {
  id            String   @id @default(cuid())
  capturedAt    DateTime @default(now())
  followerCount Int
  source        String   @default("playwright")
  userId        String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VoiceCorpusEntry {
  id          String    @id @default(cuid())
  source      String
  title       String?
  content     String
  publishedAt DateTime?
  embedding   Bytes?
  userId      String
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ScheduledPost {
  id          String   @id @default(cuid())
  postId      String   @unique
  scheduledAt DateTime
  status      String   @default("pending")
  userId      String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AppSetting {
  key       String   @id
  value     String
  iv        String?
  tag       String?
  encrypted Boolean  @default(false)
  group     String   @default("general")
  updatedAt DateTime @updatedAt
}

model LinkedInToken {
  id          String   @id @default(cuid())
  accessToken String
  tokenIv     String
  tokenTag    String
  personUrn   String
  displayName String
  expiresAt   DateTime
  userId      String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
